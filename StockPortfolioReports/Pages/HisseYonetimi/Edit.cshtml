@page "{id:long}"
@model StockPortfolioReports.Pages.HisseYonetimi.EditModel
@{
    ViewData["Title"] = "Hisse Duzenle - " + Model.Hisse.HisseAdi;
}

<h2>@Model.Hisse.HisseAdi - Duzenle</h2>

<form method="post">
    <input type="hidden" asp-for="Hisse.Id" />
    <input type="hidden" asp-for="Hisse.HisseAdi" />
    <input type="hidden" asp-for="Hisse.PiyasaAlis" />
    <input type="hidden" asp-for="Hisse.PiyasaSatis" />

    <div class="row">
        <div class="col-md-6">
            <fieldset class="border p-3 mb-3">
                <legend class="w-auto px-2 fs-6">Temel Bilgiler</legend>
                <div class="mb-2">
                    <label class="form-label">Hisse Adi</label>
                    <input class="form-control" value="@Model.Hisse.HisseAdi" readonly />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.IlkFiyat" class="form-label">Ilk Fiyat</label>
                    <input asp-for="Hisse.IlkFiyat" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.Butce" class="form-label">Butce</label>
                    <input asp-for="Hisse.Butce" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.AlimTutari" class="form-label">Alim Tutari</label>
                    <input asp-for="Hisse.AlimTutari" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.SonAlimTutari" class="form-label">Son Alim Tutari</label>
                    <input asp-for="Hisse.SonAlimTutari" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.BaslangicKademe" class="form-label">Baslangic Kademe</label>
                    <input asp-for="Hisse.BaslangicKademe" class="form-control" />
                </div>
            </fieldset>

            <fieldset class="border p-3 mb-3">
                <legend class="w-auto px-2 fs-6">Marj Ayarlari</legend>
                <div class="mb-2">
                    <label asp-for="Hisse.MarjTipi" class="form-label">Marj Tipi</label>
                    <select asp-for="Hisse.MarjTipi" class="form-select" id="marjTipiSelect">
                        <option value="0">Kademe</option>
                        <option value="1">Binde</option>
                        <option value="2">ATR</option>
                    </select>
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.Marj" class="form-label">Marj</label>
                    <input asp-for="Hisse.Marj" class="form-control" />
                </div>
            </fieldset>

            <fieldset class="border p-3 mb-3" id="atrFieldset">
                <legend class="w-auto px-2 fs-6">ATR Ayarlari</legend>
                <div class="mb-2">
                    <label asp-for="Hisse.AtrPeriyot" class="form-label">ATR Periyot</label>
                    <input asp-for="Hisse.AtrPeriyot" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.AtrCarpan" class="form-label">ATR Carpan</label>
                    <input asp-for="Hisse.AtrCarpan" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.AtrZamanDilimi" class="form-label">ATR Zaman Dilimi</label>
                    <select asp-for="Hisse.AtrZamanDilimi" class="form-select">
                        <option value="D">Gunluk</option>
                        <option value="W">Haftalik</option>
                    </select>
                </div>
            </fieldset>
        </div>

        <div class="col-md-6">
            <fieldset class="border p-3 mb-3">
                <legend class="w-auto px-2 fs-6">Hibrit Ayarlari</legend>
                <div class="mb-2">
                    <label asp-for="Hisse.CoreOran" class="form-label">Core Oran (%)</label>
                    <input asp-for="Hisse.CoreOran" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.CoreMarj" class="form-label">Core Marj (%)</label>
                    <input asp-for="Hisse.CoreMarj" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.TrailingStopYuzde" class="form-label">Trailing Stop (%)</label>
                    <input asp-for="Hisse.TrailingStopYuzde" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.ButceLimitYuzde" class="form-label">Butce Limit (%)</label>
                    <input asp-for="Hisse.ButceLimitYuzde" class="form-control" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.ButceAtrGecisYuzde" class="form-label">Butce ATR Gecis (%)</label>
                    <input asp-for="Hisse.ButceAtrGecisYuzde" class="form-control" />
                </div>
            </fieldset>

            <fieldset class="border p-3 mb-3">
                <legend class="w-auto px-2 fs-6">Durum</legend>
                <div class="mb-2">
                    <label asp-for="Hisse.PortfoyTarihi" class="form-label">Portfoy Tarihi</label>
                    <input asp-for="Hisse.PortfoyTarihi" class="form-control" type="date" />
                </div>
                <div class="mb-2">
                    <label asp-for="Hisse.SonIslemTarihi" class="form-label">Son Islem Tarihi</label>
                    <input asp-for="Hisse.SonIslemTarihi" class="form-control" type="date" />
                </div>
                <div class="form-check form-switch mb-2">
                    <input type="checkbox" name="Hisse.Aktif" value="true" class="form-check-input"
                           id="chkAktif" @(Model.Hisse.Aktif ? "checked" : "") />
                    <input type="hidden" name="Hisse.Aktif" value="false" />
                    <label class="form-check-label" for="chkAktif">Aktif</label>
                </div>
                <div class="form-check form-switch mb-2">
                    <input type="checkbox" name="Hisse.AlisAktif" value="true" class="form-check-input"
                           id="chkAlisAktif" @((Model.Hisse.AlisAktif ?? false) ? "checked" : "") />
                    <input type="hidden" name="Hisse.AlisAktif" value="false" />
                    <label class="form-check-label" for="chkAlisAktif">Alis Aktif</label>
                </div>
                <div class="form-check form-switch mb-2">
                    <input type="checkbox" name="Hisse.SatisAktif" value="true" class="form-check-input"
                           id="chkSatisAktif" @((Model.Hisse.SatisAktif ?? false) ? "checked" : "") />
                    <input type="hidden" name="Hisse.SatisAktif" value="false" />
                    <label class="form-check-label" for="chkSatisAktif">Satis Aktif</label>
                </div>
            </fieldset>

            <div class="mb-2 text-muted">
                <small>Piyasa Alis: @((Model.Hisse.PiyasaAlis ?? 0).ToString("N2")) | Piyasa Satis: @((Model.Hisse.PiyasaSatis ?? 0).ToString("N2"))</small>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a asp-page="Index" class="btn btn-secondary">Iptal</a>
    </div>
</form>

@section Scripts {
<script>
    function toggleAtr() {
        var val = document.getElementById('marjTipiSelect').value;
        document.getElementById('atrFieldset').style.display = val === '2' ? 'block' : 'none';
    }
    document.getElementById('marjTipiSelect').addEventListener('change', toggleAtr);
    toggleAtr();
</script>
}
