@page
@model StockPortfolioReports.Pages.HisseYonetimi.IndexModel
@{
    ViewData["Title"] = "Hisse Yonetimi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Hisse Yonetimi</h2>
    <a asp-page="Create" class="btn btn-primary">Yeni Hisse Ekle</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <select class="form-select" name="HisseFiltre">
            <option value="">Tum Hisseler</option>
            @foreach (var h in Model.HisseListesi)
            {
                <option value="@h" selected="@(Model.HisseFiltre == h)">@h</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <select class="form-select" name="AktifFiltre">
            <option value="" selected="@(string.IsNullOrEmpty(Model.AktifFiltre))">Aktif: Tumu</option>
            <option value="aktif" selected="@(Model.AktifFiltre == "aktif")">Aktif: ON</option>
            <option value="pasif" selected="@(Model.AktifFiltre == "pasif")">Aktif: OFF</option>
        </select>
    </div>
    <div class="col-auto">
        <select class="form-select" name="AlisFiltre">
            <option value="" selected="@(string.IsNullOrEmpty(Model.AlisFiltre))">Alis: Tumu</option>
            <option value="aktif" selected="@(Model.AlisFiltre == "aktif")">Alis: ON</option>
            <option value="pasif" selected="@(Model.AlisFiltre == "pasif")">Alis: OFF</option>
        </select>
    </div>
    <div class="col-auto">
        <select class="form-select" name="SatisFiltre">
            <option value="" selected="@(string.IsNullOrEmpty(Model.SatisFiltre))">Satis: Tumu</option>
            <option value="aktif" selected="@(Model.SatisFiltre == "aktif")">Satis: ON</option>
            <option value="pasif" selected="@(Model.SatisFiltre == "pasif")">Satis: OFF</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filtrele</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Hisse</th>
                <th class="text-end">Butce</th>
                <th class="text-end">Alim Tutari</th>
                <th class="text-end">Marj</th>
                <th>Marj Tipi</th>
                <th class="text-end">Piyasa Satis</th>
                <th class="text-center">Aktif</th>
                <th class="text-center">Alis</th>
                <th class="text-center">Satis</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var h in Model.Hisseler)
            {
                <tr>
                    <td>
                        <a asp-page="/HisseDetay" asp-route-hisse="@h.HisseAdi" class="fw-bold text-decoration-none">@h.HisseAdi</a>
                    </td>
                    <td class="text-end">@h.Butce.ToString("N0")</td>
                    <td class="text-end">@h.AlimTutari.ToString("N0")</td>
                    <td class="text-end">@(h.Marj ?? 0)</td>
                    <td>
                        @if ((h.MarjTipi ?? 0) == 0)
                        {
                            <span class="badge bg-secondary">Kademe</span>
                        }
                        else if ((h.MarjTipi ?? 0) == 1)
                        {
                            <span class="badge bg-info">Binde</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">ATR</span>
                        }
                    </td>
                    <td class="text-end">@((h.PiyasaSatis ?? 0).ToString("N2"))</td>
                    <td class="text-center">
                        <form method="post" asp-page-handler="Toggle" style="display:inline">
                            <input type="hidden" name="id" value="@h.Id" />
                            <input type="hidden" name="field" value="Aktif" />
                            <input type="hidden" name="hisseFiltre" value="@Model.HisseFiltre" />
                            <input type="hidden" name="aktifFiltre" value="@Model.AktifFiltre" />
                            <input type="hidden" name="alisFiltre" value="@Model.AlisFiltre" />
                            <input type="hidden" name="satisFiltre" value="@Model.SatisFiltre" />
                            <button type="submit" class="btn btn-sm @(h.Aktif ? "btn-success" : "btn-outline-secondary")">
                                @(h.Aktif ? "ON" : "OFF")
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        <form method="post" asp-page-handler="Toggle" style="display:inline">
                            <input type="hidden" name="id" value="@h.Id" />
                            <input type="hidden" name="field" value="AlisAktif" />
                            <input type="hidden" name="hisseFiltre" value="@Model.HisseFiltre" />
                            <input type="hidden" name="aktifFiltre" value="@Model.AktifFiltre" />
                            <input type="hidden" name="alisFiltre" value="@Model.AlisFiltre" />
                            <input type="hidden" name="satisFiltre" value="@Model.SatisFiltre" />
                            <button type="submit" class="btn btn-sm @((h.AlisAktif ?? false) ? "btn-success" : "btn-outline-secondary")">
                                @((h.AlisAktif ?? false) ? "ON" : "OFF")
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        <form method="post" asp-page-handler="Toggle" style="display:inline">
                            <input type="hidden" name="id" value="@h.Id" />
                            <input type="hidden" name="field" value="SatisAktif" />
                            <input type="hidden" name="hisseFiltre" value="@Model.HisseFiltre" />
                            <input type="hidden" name="aktifFiltre" value="@Model.AktifFiltre" />
                            <input type="hidden" name="alisFiltre" value="@Model.AlisFiltre" />
                            <input type="hidden" name="satisFiltre" value="@Model.SatisFiltre" />
                            <button type="submit" class="btn btn-sm @((h.SatisAktif ?? false) ? "btn-success" : "btn-outline-secondary")">
                                @((h.SatisAktif ?? false) ? "ON" : "OFF")
                            </button>
                        </form>
                    </td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@h.Id" class="btn btn-sm btn-outline-primary">Duzenle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
