@page
@model StockPortfolioReports.Pages.Arbitraj.AyarlarModel
@{
    ViewData["Title"] = "Arbitraj Ayarlari";
}

<h2 class="mb-3">Arbitraj Ayarlari</h2>

<!-- Global Butce -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="mb-3">Global Butce</h6>
        <form method="post" asp-page-handler="Butce" class="row g-3 align-items-end">
            <div class="col-auto">
                <label class="form-label">Butce (TL)</label>
                <input type="number" name="butce" class="form-control" value="@Model.GlobalButce.ToString("F0")" step="1000" min="0" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Hisse</th>
                <th>Tip</th>
                <th>Yakin Vade</th>
                <th>Uzak Vade</th>
                <th class="text-end">BIST Lot</th>
                <th class="text-end">VIOP Lot</th>
                <th class="text-end">Giris Marji</th>
                <th class="text-end">Cikis Marji</th>
                <th class="text-end">Yillik Faiz</th>
                <th class="text-end">Temettu</th>
                <th class="text-center">Aktif</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Configler)
            {
                var tipLabel = c.ArbitrajTipi == 0 ? "Spot-VIOP" : "Takvim Spread";
                var tipBadge = c.ArbitrajTipi == 0 ? "bg-primary" : "bg-info";
                <tr>
                    <td class="fw-bold">@c.HisseAdi</td>
                    <td><span class="badge @tipBadge">@tipLabel</span></td>
                    <td>
                        @c.YakinVadeKodu
                        <br /><small class="text-muted">@c.YakinVadeSonGun.ToString("dd.MM.yyyy")</small>
                    </td>
                    <td>
                        @(c.UzakVadeKodu ?? "-")
                        @if (c.UzakVadeSonGun.HasValue)
                        {
                            <br /><small class="text-muted">@c.UzakVadeSonGun.Value.ToString("dd.MM.yyyy")</small>
                        }
                    </td>
                    <td class="text-end">@c.BistLot</td>
                    <td class="text-end">@c.ViopLot</td>
                    <td class="text-end">%@c.GirisMarji.ToString("N1")</td>
                    <td class="text-end">%@c.CikisMarji.ToString("N1")</td>
                    <td class="text-end">%@c.YillikFaiz.ToString("N1")</td>
                    <td class="text-end">
                        @if (c.TemettuTutar > 0)
                        {
                            <span>@c.TemettuTutar.ToString("N2") TL</span>
                            @if (c.TemettuTarihi.HasValue)
                            {
                                <br /><small class="text-muted">@c.TemettuTarihi.Value.ToString("dd.MM.yyyy")</small>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-center">
                        <form method="post" asp-page-handler="Toggle" style="display:inline">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="btn btn-sm @(c.AktifMi ? "btn-success" : "btn-outline-secondary")">
                                @(c.AktifMi ? "ON" : "OFF")
                            </button>
                        </form>
                    </td>
                    <td>
                        <a asp-page="AyarDuzenle" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Duzenle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
