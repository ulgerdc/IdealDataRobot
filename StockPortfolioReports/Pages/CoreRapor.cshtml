@page
@model StockPortfolioReports.Pages.CoreRaporModel
@{
    ViewData["Title"] = "Core Pozisyon Raporu";
}

<h4>Core Pozisyon Raporu</h4>

<!-- Filtre -->
<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">Hisse</label>
        <select class="form-select" name="HisseFiltre">
            <option value="">Tumu</option>
            @foreach (var h in Model.HisseListesi)
            {
                <option value="@h" selected="@(Model.HisseFiltre == h)">@h</option>
            }
        </select>
    </div>
    <div class="col-auto d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Filtrele</button>
    </div>
</form>

<!-- Ozet Kartlari -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-dark text-white">
            <div class="card-body">
                <h6 class="card-title">Aktif Core</h6>
                <h4>@Model.ToplamAdet poz / @Model.ToplamLot lot</h4>
                <small>Bekleyen pozisyonlar</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6 class="card-title">Toplam Maliyet</h6>
                <h4>@Model.ToplamMaliyet.ToString("N0") TL</h4>
                <small>Alis maliyeti</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-secondary text-white">
            <div class="card-body">
                <h6 class="card-title">Guncel Deger</h6>
                <h4>@Model.ToplamGuncelDeger.ToString("N0") TL</h4>
                <small>Piyasa degeri</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.ToplamKZ >= 0 ? "bg-success" : "bg-danger")">
            <div class="card-body">
                <h6 class="card-title">Acik K/Z</h6>
                <h4>@Model.ToplamKZ.ToString("N2") TL</h4>
                @if (Model.ToplamMaliyet > 0)
                {
                    <small>%@((Model.ToplamKZ / Model.ToplamMaliyet * 100).ToString("N2"))</small>
                }
            </div>
        </div>
    </div>
</div>

<!-- Hisse Bazli Tablo -->
<div class="card mb-4">
    <div class="card-header">
        <strong>Hisse Bazli Core Pozisyonlar</strong>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Hisse</th>
                    <th class="text-end">Adet</th>
                    <th class="text-end">Lot</th>
                    <th class="text-end">Ort Maliyet</th>
                    <th class="text-end">Guncel Fiyat</th>
                    <th class="text-end">Maliyet TL</th>
                    <th class="text-end">Guncel Deger</th>
                    <th class="text-end">Acik K/Z</th>
                    <th class="text-end">K/Z %</th>
                    <th class="text-end">Ort Gun</th>
                    <th class="text-end">Kapanan</th>
                    <th class="text-end">Gerceklesen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.HisseDetaylari)
                {
                    <tr>
                        <td><strong>@h.HisseAdi</strong></td>
                        <td class="text-end">@h.AktifAdet</td>
                        <td class="text-end">@h.AktifLot</td>
                        <td class="text-end">@h.OrtMaliyet.ToString("N2")</td>
                        <td class="text-end">@h.GuncelFiyat.ToString("N2")</td>
                        <td class="text-end">@h.Maliyet.ToString("N0")</td>
                        <td class="text-end">@h.GuncelDeger.ToString("N0")</td>
                        <td class="text-end @(h.AktifKZ >= 0 ? "text-success" : "text-danger")">
                            <strong>@h.AktifKZ.ToString("N2")</strong>
                        </td>
                        <td class="text-end @(h.AktifKZYuzde >= 0 ? "text-success" : "text-danger")">
                            %@h.AktifKZYuzde.ToString("N2")
                        </td>
                        <td class="text-end">@h.OrtTutmaGun</td>
                        <td class="text-end">@h.KapananAdet</td>
                        <td class="text-end @(h.GerceklesenKar >= 0 ? "text-success" : "text-danger")">
                            @h.GerceklesenKar.ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.HisseDetaylari.Any())
            {
                <tfoot class="table-dark">
                    <tr>
                        <td><strong>TOPLAM</strong></td>
                        <td class="text-end">@Model.ToplamAdet</td>
                        <td class="text-end">@Model.ToplamLot</td>
                        <td class="text-end">-</td>
                        <td class="text-end">-</td>
                        <td class="text-end">@Model.ToplamMaliyet.ToString("N0")</td>
                        <td class="text-end">@Model.ToplamGuncelDeger.ToString("N0")</td>
                        <td class="text-end @(Model.ToplamKZ >= 0 ? "text-success" : "text-danger")">
                            <strong>@Model.ToplamKZ.ToString("N2")</strong>
                        </td>
                        <td class="text-end @(Model.ToplamKZ >= 0 ? "text-success" : "text-danger")">
                            @if (Model.ToplamMaliyet > 0)
                            {
                                <text>%@((Model.ToplamKZ / Model.ToplamMaliyet * 100).ToString("N2"))</text>
                            }
                        </td>
                        <td class="text-end">-</td>
                        <td class="text-end">@Model.HisseDetaylari.Sum(h => h.KapananAdet)</td>
                        <td class="text-end @(Model.HisseDetaylari.Sum(h => h.GerceklesenKar) >= 0 ? "text-success" : "text-danger")">
                            @Model.HisseDetaylari.Sum(h => h.GerceklesenKar).ToString("N2")
                        </td>
                    </tr>
                </tfoot>
            }
        </table>
        @if (!Model.HisseDetaylari.Any())
        {
            <div class="text-center text-muted py-4">Core pozisyon bulunamadi.</div>
        }
    </div>
</div>

<!-- Bar Chart -->
@if (Model.HisseDetaylari.Any(h => h.AktifLot > 0))
{
    <div class="card mb-4">
        <div class="card-header"><strong>Core K/Z Dagilimi</strong></div>
        <div class="card-body">
            <canvas id="coreKZChart" height="100"></canvas>
        </div>
    </div>
}

@section Scripts {
    <script>
        var chartData = @Html.Raw(Model.CoreKZJson);
        if (chartData.labels && chartData.labels.length > 0) {
            new Chart(document.getElementById('coreKZChart'), {
                type: 'bar',
                data: {
                    labels: chartData.labels,
                    datasets: [
                        {
                            label: 'Acik K/Z',
                            data: chartData.kzData,
                            backgroundColor: chartData.kzData.map(v => v >= 0
                                ? 'rgba(40, 167, 69, 0.7)' : 'rgba(220, 53, 69, 0.7)'),
                            borderColor: chartData.kzData.map(v => v >= 0
                                ? 'rgba(40, 167, 69, 1)' : 'rgba(220, 53, 69, 1)'),
                            borderWidth: 1
                        },
                        {
                            label: 'Gerceklesen Kar',
                            data: chartData.gerceklesenData,
                            backgroundColor: 'rgba(13, 110, 253, 0.5)',
                            borderColor: 'rgba(13, 110, 253, 1)',
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            ticks: {
                                callback: function(v) { return v.toLocaleString('tr-TR') + ' TL'; }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(ctx) {
                                    return ctx.dataset.label + ': ' + ctx.parsed.y.toLocaleString('tr-TR') + ' TL';
                                }
                            }
                        }
                    }
                }
            });
        }
    </script>
}
