@page
@model PerformanceAnalysisModel
@{
    ViewData["Title"] = "Performans Analizi";
}

<h2 class="mb-3">Performans Analizi</h2>

<!-- Istatistik kartlari -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">Toplam Islem</h6>
                <h3>@Model.ToplamIslem</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">Kazanc Orani</h6>
                <h3 class="@(Model.KazancOrani >= 50 ? "text-success" : "text-danger")">%@Model.KazancOrani</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">Ort. Kar/Islem</h6>
                <h3 class="@(Model.OrtalamaKar >= 0 ? "text-success" : "text-danger")">@Model.OrtalamaKar.ToString("N0") TL</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <h6 class="text-muted">Ort. Tutma Suresi</h6>
                <h3>@Model.OrtalamaTutmaSuresi gun</h3>
            </div>
        </div>
    </div>
</div>

<!-- Kumulatif kar chart -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6>Kumulatif Kar</h6>
        <canvas id="kumulatifChart" height="150"></canvas>
    </div>
</div>

<!-- Aylik kar chart -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6>Aylik Kar/Zarar</h6>
        <canvas id="aylikChart" height="150"></canvas>
    </div>
</div>

<!-- Grid vs Core karsilastirma -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h6>Grid vs Core Karsilastirma (Kapanan Islemler)</h6>
        <table class="table table-sm">
            <thead class="table-dark">
                <tr>
                    <th>Tip</th>
                    <th class="text-end">Islem Sayisi</th>
                    <th class="text-end">Toplam Kar</th>
                    <th class="text-end">Kazanc Orani</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="badge bg-primary">Grid</span></td>
                    <td class="text-end">@Model.GridIslem</td>
                    <td class="text-end @(Model.GridToplam >= 0 ? "text-success" : "text-danger")">@Model.GridToplam.ToString("N0") TL</td>
                    <td class="text-end">%@Model.GridKazancOrani</td>
                </tr>
                <tr>
                    <td><span class="badge bg-warning text-dark">Core</span></td>
                    <td class="text-end">@Model.CoreIslem</td>
                    <td class="text-end @(Model.CoreToplam >= 0 ? "text-success" : "text-danger")">@Model.CoreToplam.ToString("N0") TL</td>
                    <td class="text-end">%@Model.CoreKazancOrani</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    var kum = @Html.Raw(Model.KumulatifKarJson);
    new Chart(document.getElementById('kumulatifChart'), {
        type: 'line',
        data: {
            labels: kum.labels,
            datasets: [{
                label: 'Kumulatif Kar (TL)',
                data: kum.data,
                borderColor: '#198754',
                backgroundColor: 'rgba(25,135,84,0.1)',
                fill: true,
                tension: 0.3,
                pointRadius: 0
            }]
        },
        options: { responsive: true, plugins: { legend: { display: false } } }
    });

    var aylik = @Html.Raw(Model.AylikKarJson);
    var aylikColors = aylik.data.map(v => v >= 0 ? '#198754' : '#dc3545');
    new Chart(document.getElementById('aylikChart'), {
        type: 'bar',
        data: {
            labels: aylik.labels,
            datasets: [{
                label: 'Aylik Kar (TL)',
                data: aylik.data,
                backgroundColor: aylikColors
            }]
        },
        options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
</script>
}
