<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfoy Yonetimi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StockPortfolioReports.styles.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Portfoy Yonetimi</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Raporlar
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/PortfolioSummary">Kar/Zarar Ozeti</a></li>
                                <li><a class="dropdown-item" asp-page="/ActiveHoldings">Aktif Pozisyonlar</a></li>
                                <li><a class="dropdown-item" asp-page="/SoldReports">Satilan Hisseler</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/GroupedSummary">Gruplu Ozet</a></li>
                                <li><a class="dropdown-item" asp-page="/DailySummary">Gunluk Ozet</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/GridCoreSummary">Grid/Core Ayrimi</a></li>
                                <li><a class="dropdown-item" asp-page="/PerformanceAnalysis">Performans Analizi</a></li>
                                <li><a class="dropdown-item" asp-page="/StratejiDogrulama">Strateji Dogrulama</a></li>
                                <li><a class="dropdown-item" asp-page="/GunlukRapor">Gunluk Rapor</a></li>
                                <li><a class="dropdown-item" asp-page="/CoreRapor">Core Rapor</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Arbitraj
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Arbitraj/Index">Arbitraj Dashboard</a></li>
                                <li><a class="dropdown-item" asp-page="/Arbitraj/SpreadGecmisi">Spread Gecmisi</a></li>
                                <li><a class="dropdown-item" asp-page="/Arbitraj/Pozisyonlar">Pozisyonlar</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Arbitraj/Ayarlar">Ayarlar</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Yonetim
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/HisseYonetimi/Index">Hisse Yonetimi</a></li>
                                <li><a class="dropdown-item" asp-page="/RiskLog">Risk Loglari</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Portfoy Yonetimi
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
