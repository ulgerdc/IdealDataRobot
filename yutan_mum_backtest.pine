e30 = input.bool(true, "TAVHL", group=grp_hisse, inline="r6")
e31 = input.bool(true, "TCELL", group=grp_hisse, inline="r7")
e32 = input.bool(true, "THYAO", group=grp_hisse, inline="r7")
e33 = input.bool(true, "TOASO", group=grp_hisse, inline="r7")
e34 = input.bool(true, "TTKOM", group=grp_hisse, inline="r7")
e35 = input.bool(true, "TUPRS", group=grp_hisse, inline="r7")
e36 = input.bool(true, "ULKER", group=grp_hisse, inline="r8")
e37 = input.bool(true, "VAKBN", group=grp_hisse, inline="r8")
e38 = input.bool(true, "YKBNK", group=grp_hisse, inline="r8")

// ==================== SABITLER ====================
int MAX_HISSE = 38

// ==================== VERI ALMA ====================
tf = "D"

// XU100 endeks verisi
[xu100O, xu100C] = request.security("BIST:XU100", tf, [open, close], lookahead=barmerge.lookahead_off)
endeksPozitif = xu100C > xu100O

// 38 hisse — her biri tek request.security cagrisi
[o01,c01,v01,po01,pc01,pv01] = request.security("BIST:AKBNK", tf, [open,close,volume,open[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o02,c02,v02,po02,pc02,pv02] = request.security("BIST:AKSEN", tf, [open,close,volume,open[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
