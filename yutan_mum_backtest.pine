// © Yutan Mum (Engulfing Candle) Overnight Batch Backtest
// Kapanista engulfing sinyal veren hisseleri toplu al, ertesi gun acilista toplu sat
// Endeks filtresi: XU100 pozitif olma zorunlulugu

//@version=5
indicator("Yutan Mum Overnight Backtest", overlay=false, max_labels_count=500, max_lines_count=500)

// ==================== PARAMETRELER ====================
grp_date    = "Tarih Araligi"
grp_strat   = "Strateji Ayarlari"
grp_endeks  = "Endeks Filtresi"
grp_hisse   = "Hisse Secimi (BIST100)"

startDate   = input.time(timestamp("2024-01-01 00:00 +0300"), "Baslangic Tarihi", group=grp_date)
endDate     = input.time(timestamp("2026-02-25 23:59 +0300"), "Bitis Tarihi",     group=grp_date)

toplamButce     = input.float(100000, "Toplam Butce (TL)",        minval=10000, step=10000, group=grp_strat)
minHacimCarpani = input.float(1.0,    "Min Hacim Carpani",        minval=0.5, maxval=5.0, step=0.1, group=grp_strat)
minButcePerHisse= input.float(1000,   "Min Butce/Hisse (TL)",     minval=100, step=100, group=grp_strat)

endeksFiltresi  = input.bool(true,    "Endeks Pozitif Filtresi",  group=grp_endeks, tooltip="XU100 gun icinde pozitif degilse sinyal uretilmez")

// BIST100 temsili 38 hisse (bankalar, sanayi, enerji, tuketim, teknoloji, madencilik)
e01 = input.bool(true, "AKBNK", group=grp_hisse, inline="r1")
e02 = input.bool(true, "AKSEN", group=grp_hisse, inline="r1")
e03 = input.bool(true, "ALARK", group=grp_hisse, inline="r1")
e04 = input.bool(true, "ARCLK", group=grp_hisse, inline="r1")
e05 = input.bool(true, "ASELS", group=grp_hisse, inline="r1")
e06 = input.bool(true, "BIMAS", group=grp_hisse, inline="r2")
e07 = input.bool(true, "CCOLA", group=grp_hisse, inline="r2")
e08 = input.bool(true, "CIMSA", group=grp_hisse, inline="r2")
e09 = input.bool(true, "DOAS",  group=grp_hisse, inline="r2")
e10 = input.bool(true, "EKGYO", group=grp_hisse, inline="r2")
e11 = input.bool(true, "ENJSA", group=grp_hisse, inline="r3")
e12 = input.bool(true, "ENKAI", group=grp_hisse, inline="r3")
e13 = input.bool(true, "EREGL", group=grp_hisse, inline="r3")
e14 = input.bool(true, "FROTO", group=grp_hisse, inline="r3")
e15 = input.bool(true, "GARAN", group=grp_hisse, inline="r3")
e16 = input.bool(true, "GESAN", group=grp_hisse, inline="r4")
e17 = input.bool(true, "GUBRF", group=grp_hisse, inline="r4")
e18 = input.bool(true, "HALKB", group=grp_hisse, inline="r4")
e19 = input.bool(true, "ISCTR", group=grp_hisse, inline="r4")
e20 = input.bool(true, "KCHOL", group=grp_hisse, inline="r4")
e21 = input.bool(true, "KOZAL", group=grp_hisse, inline="r5")
e22 = input.bool(true, "MGROS", group=grp_hisse, inline="r5")
e23 = input.bool(true, "ODAS",  group=grp_hisse, inline="r5")
e24 = input.bool(true, "PETKM", group=grp_hisse, inline="r5")
e25 = input.bool(true, "PGSUS", group=grp_hisse, inline="r5")
e26 = input.bool(true, "SAHOL", group=grp_hisse, inline="r6")
e27 = input.bool(true, "SASA",  group=grp_hisse, inline="r6")
e28 = input.bool(true, "SISE",  group=grp_hisse, inline="r6")
