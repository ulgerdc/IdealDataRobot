// ==================== MOMENTUM SINYAL TESPITI ====================
// Kapanis zirveye yakin + gun ici momentum + hacim artisi + dunden yukari
// Opsiyonel: + Engulfing pattern
momentumSinyal(idx) =>
    if not array.get(arrAktif, idx)
        false
    else
        _o  = array.get(arrO, idx)
        _h  = array.get(arrH, idx)
        _l  = array.get(arrL, idx)
        _c  = array.get(arrC, idx)
        _v  = array.get(arrV, idx)
        _o1 = array.get(arrO1, idx)
        _h1 = array.get(arrH1, idx)
        _c1 = array.get(arrC1, idx)
        _v1 = array.get(arrV1, idx)
        if _o <= 0 or _c <= 0 or _h <= 0 or _l <= 0
            false
        else
            // Kapanis zirveye yakin: (Close - Low) / (High - Low) > threshold
            gunRange = _h - _l
            closePos = gunRange > 0 ? (_c - _l) / gunRange : 0.5
            closePosOK = closePos >= closeThreshold

            // Gun ici momentum: (Close - Open) / Open * 100 > min%
            momentum = _o > 0 ? (_c - _o) / _o * 100 : 0
            momentumOK = momentum >= minMomentum

            // Hacim artisi: bugun > dunku * carpan
            hacimOK = _v1 > 0 ? _v >= _v1 * volCarpani : true

            // Dunku kapanisin ustu
            dununOK = dununUstuZorunlu ? _c > _c1 and _c1 > 0 : true

            momOK = closePosOK and momentumOK and hacimOK and dununOK

            // Opsiyonel engulfing filtresi
            engOK = true
            if engulfingEk and _o1 > 0 and _c1 > 0
                dunkuKirmizi = _c1 < _o1
                yutma = _o <= _c1 and _c >= _o1
                hacimEngOK = _v > _v1 * minHacimCarpani
                engOK := dunkuKirmizi and yutma and hacimEngOK

            momOK and engOK

// ==================== OVERNIGHT STATE ====================
var float[] oncekiAlis = array.new_float(MAX_HISSE, 0.0)
var int[]   oncekiLot  = array.new_int(MAX_HISSE, 0)
var bool    oncekiBatchVar = false
var int     oncekiHisseSay = 0

// Istatistikler
var int   toplamBatch     = 0
var int   kazancBatch     = 0
var int   kayipBatch      = 0
var float toplamKar       = 0.0
var float toplamZarar     = 0.0
var float kumulatifKZ     = 0.0
var float maxDrawdown     = 0.0
var float zirveSermaye    = 0.0
var int   toplamSinyal    = 0
var float enIyiBatch      = 0.0
var float enKotuBatch     = 0.0
var int   endeksEngel     = 0

// Son 10 batch (ring buffer)
var int    RING_SIZE       = 10
var int[]    sonBatchHisse  = array.new_int(10, 0)
var float[]  sonBatchKar    = array.new_float(10, 0.0)
var float[]  sonBatchYuzde  = array.new_float(10, 0.0)
var int      sonBatchIdx    = 0

// Tarih filtresi
inDateRange = time >= startDate and time <= endDate

// Gorsel flag'ler
var bool satisBatch = false
var bool alisBatch  = false
var bool endeksBlok = false
satisBatch := false
alisBatch  := false
endeksBlok := false

var float buBarKZ = 0.0
buBarKZ := 0.0

if inDateRange
    // ---- 1. ONCEKI BATCH'I ACILISTA SAT ----
    if oncekiBatchVar
        batchKZ = 0.0
        batchAlim = 0.0
        for j = 0 to MAX_HISSE - 1
            lot = array.get(oncekiLot, j)
            if lot > 0
                alisFiyati = array.get(oncekiAlis, j)
                satisFiyati = array.get(arrO, j)
                if satisFiyati > 0
                    kz = lot * (satisFiyati - alisFiyati)
                    batchKZ += kz
                    batchAlim += lot * alisFiyati
                array.set(oncekiAlis, j, 0.0)
                array.set(oncekiLot,  j, 0)

        toplamBatch := toplamBatch + 1
        if batchKZ >= 0
            kazancBatch := kazancBatch + 1
            toplamKar   := toplamKar + batchKZ
        else
            kayipBatch  := kayipBatch + 1
            toplamZarar := toplamZarar + batchKZ

        kumulatifKZ := kumulatifKZ + batchKZ
        if kumulatifKZ > zirveSermaye
            zirveSermaye := kumulatifKZ
        dd = zirveSermaye - kumulatifKZ
        if dd > maxDrawdown
            maxDrawdown := dd

        if batchKZ > enIyiBatch
            enIyiBatch := batchKZ
        if batchKZ < enKotuBatch
            enKotuBatch := batchKZ

        ringIdx = sonBatchIdx % RING_SIZE
        array.set(sonBatchHisse, ringIdx, oncekiHisseSay)
        array.set(sonBatchKar,   ringIdx, batchKZ)
        batchYuzde = batchAlim > 0 ? batchKZ / batchAlim * 100 : 0
        array.set(sonBatchYuzde, ringIdx, batchYuzde)
        sonBatchIdx := sonBatchIdx + 1

        oncekiBatchVar := false
        oncekiHisseSay := 0
        satisBatch := true
        buBarKZ := batchKZ

    // ---- 2. BUGUN SINYAL TARA ----
    sinyalIdxler = array.new_int(0)
    for j = 0 to MAX_HISSE - 1
        if momentumSinyal(j)
            array.push(sinyalIdxler, j)

    sinyalSay = array.size(sinyalIdxler)
    if sinyalSay > 0
        if endeksFiltresi and not endeksPozitif
            endeksEngel := endeksEngel + 1
            endeksBlok := true
        else
            toplamSinyal := toplamSinyal + sinyalSay

            hisseBasiButce = toplamButce / sinyalSay
            if hisseBasiButce < minButcePerHisse
                maxHisse = math.floor(toplamButce / minButcePerHisse)
                if maxHisse > 0
                    while array.size(sinyalIdxler) > maxHisse
                        array.pop(sinyalIdxler)
                    sinyalSay := array.size(sinyalIdxler)
                    hisseBasiButce := toplamButce / sinyalSay

            if sinyalSay > 0 and hisseBasiButce >= minButcePerHisse
                hisseSayaci = 0
                for k = 0 to sinyalSay - 1
                    j = array.get(sinyalIdxler, k)
                    fiyat = array.get(arrC, j)
                    if fiyat > 0
                        lot = math.floor(hisseBasiButce / fiyat)
                        if lot < 1
                            lot := 1
                        array.set(oncekiAlis, j, fiyat)
                        array.set(oncekiLot,  j, int(lot))
                        hisseSayaci += 1

                if hisseSayaci > 0
                    oncekiBatchVar := true
                    oncekiHisseSay := hisseSayaci
                    alisBatch := true

// ==================== GORSEL ====================
plot(inDateRange ? kumulatifKZ : na, "Kumulatif K/Z", color=color.new(color.blue, 0), linewidth=2)
hline(0, "Basabas", color=color.gray, linestyle=hline.style_dashed)

plot(inDateRange and satisBatch ? buBarKZ : na, "Batch K/Z", color=buBarKZ >= 0 ? color.green : color.red, linewidth=4, style=plot.style_histogram)

plotshape(inDateRange and alisBatch,  title="Kapanista Alis",  style=shape.triangleup,   location=location.bottom, color=color.green, size=size.small)
plotshape(inDateRange and satisBatch and buBarKZ >= 0, title="Acilista Satis +", style=shape.triangledown, location=location.top, color=color.blue, size=size.small)
plotshape(inDateRange and satisBatch and buBarKZ < 0,  title="Acilista Satis -", style=shape.triangledown, location=location.top, color=color.red,  size=size.small)
plotshape(inDateRange and endeksBlok, title="Endeks Engel", style=shape.xcross, location=location.bottom, color=color.orange, size=size.tiny)

bgcolor(inDateRange and oncekiBatchVar ? color.new(color.green, 92) : na, title="Pozisyon Acik")

// ==================== DASHBOARD ====================
if barstate.islast
    var table dash = table.new(position.top_right, 2, 40, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)

    aktifHisseSay = 0
    for j = 0 to MAX_HISSE - 1
        if array.get(arrAktif, j)
            aktifHisseSay += 1

    row = 0
    table.cell(dash, 0, row, "MOMENTUM OVERNIGHT (BIST30)", bgcolor=color.new(color.orange, 20), text_color=color.white, text_size=size.normal)
    table.cell(dash, 1, row, "", bgcolor=color.new(color.orange, 20))
    table.merge_cells(dash, 0, row, 1, row)

    row += 1
    table.cell(dash, 0, row, "Hisse Sayisi", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(aktifHisseSay), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Butce", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(toplamButce, "#,###") + " TL", text_color=color.white, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Mod", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, "Kapanis Al → Acilis Sat", text_color=color.yellow, text_size=size.small, text_halign=text.align_right)

    // Momentum parametreleri
    row += 1
    table.cell(dash, 0, row, "FILTRE AYARLARI", bgcolor=color.new(color.maroon, 30), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, row, "", bgcolor=color.new(color.maroon, 30))
    table.merge_cells(dash, 0, row, 1, row)

    row += 1
    table.cell(dash, 0, row, "Close/Zirve Esigi", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(closeThreshold * 100, "#.#") + "% (ust %" + str.tostring((1-closeThreshold)*100, "#.#") + ")", text_color=color.white, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Min Momentum", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, "%" + str.tostring(minMomentum, "#.#"), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Hacim (vs dunku)", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(volCarpani, "#.#") + "x", text_color=color.white, text_size=size.small, text_halign=text.align_right)

    row += 1
    dununDurum = dununUstuZorunlu ? "AKTIF" : "KAPALI"
    dununRenk  = dununUstuZorunlu ? color.green : color.gray
    table.cell(dash, 0, row, "Dunku Close Ustu", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, dununDurum, text_color=dununRenk, text_size=size.small, text_halign=text.align_right)

    row += 1
    engDurum = engulfingEk ? "AKTIF" : "KAPALI"
    engRenk  = engulfingEk ? color.green : color.gray
    table.cell(dash, 0, row, "Engulfing Filtre", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, engDurum, text_color=engRenk, text_size=size.small, text_halign=text.align_right)

    row += 1
    endeksDurum = endeksFiltresi ? "AKTIF" : "KAPALI"
    endeksRenk  = endeksFiltresi ? color.green : color.gray
    table.cell(dash, 0, row, "XU100 Filtre", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, endeksDurum + " (" + str.tostring(endeksEngel) + " engel)", text_color=endeksRenk, text_size=size.small, text_halign=text.align_right)

    // --- BATCH ISTATISTIK ---
    row += 1
    table.cell(dash, 0, row, "BATCH ISTATISTIK", bgcolor=color.new(color.teal, 30), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, row, "", bgcolor=color.new(color.teal, 30))
    table.merge_cells(dash, 0, row, 1, row)

    row += 1
    table.cell(dash, 0, row, "Toplam Batch", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(toplamBatch), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    winPct = toplamBatch > 0 ? kazancBatch / toplamBatch * 100 : 0
    row += 1
    table.cell(dash, 0, row, "Kazancli", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(kazancBatch) + " (%" + str.tostring(winPct, "#.0") + ")", text_color=color.green, text_size=size.small, text_halign=text.align_right)

    losePct = toplamBatch > 0 ? kayipBatch / toplamBatch * 100 : 0
    row += 1
    table.cell(dash, 0, row, "Kayipli", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(kayipBatch) + " (%" + str.tostring(losePct, "#.0") + ")", text_color=color.red, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Toplam Sinyal", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(toplamSinyal), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    avgHisse = toplamBatch > 0 ? toplamSinyal / toplamBatch : 0
    row += 1
    table.cell(dash, 0, row, "Ort. Hisse/Batch", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(avgHisse, "#.#"), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    // --- PERFORMANS ---
    row += 1
    table.cell(dash, 0, row, "PERFORMANS", bgcolor=color.new(color.purple, 30), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, row, "", bgcolor=color.new(color.purple, 30))
    table.merge_cells(dash, 0, row, 1, row)

    row += 1
    table.cell(dash, 0, row, "Toplam Kar", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, "+" + str.tostring(toplamKar, "#,###") + " TL", text_color=color.green, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Toplam Zarar", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(toplamZarar, "#,###") + " TL", text_color=color.red, text_size=size.small, text_halign=text.align_right)

    netKZ = toplamKar + toplamZarar
    netRenk = netKZ >= 0 ? color.green : color.red
    row += 1
    table.cell(dash, 0, row, "Net K/Z", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(netKZ, "#,###") + " TL", text_color=netRenk, text_size=size.small, text_halign=text.align_right)

    roi = toplamButce > 0 ? netKZ / toplamButce * 100 : 0
    row += 1
    table.cell(dash, 0, row, "ROI", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, "%" + str.tostring(roi, "#.##"), text_color=netRenk, text_size=size.small, text_halign=text.align_right)

    profitFactor = toplamZarar != 0 ? math.abs(toplamKar / toplamZarar) : 0
    row += 1
    table.cell(dash, 0, row, "Profit Factor", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(profitFactor, "#.##"), text_color=profitFactor >= 1 ? color.green : color.red, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "Max Drawdown", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(maxDrawdown, "#,###") + " TL", text_color=color.orange, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "En Iyi Batch", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, "+" + str.tostring(enIyiBatch, "#,###") + " TL", text_color=color.green, text_size=size.small, text_halign=text.align_right)

    row += 1
    table.cell(dash, 0, row, "En Kotu Batch", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, row, str.tostring(enKotuBatch, "#,###") + " TL", text_color=color.red, text_size=size.small, text_halign=text.align_right)

    // --- SON BATCHLER ---
    row += 1
    table.cell(dash, 0, row, "SON BATCHLER", bgcolor=color.new(color.orange, 30), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, row, "", bgcolor=color.new(color.orange, 30))
    table.merge_cells(dash, 0, row, 1, row)

    sonBatchGoster = math.min(sonBatchIdx, RING_SIZE)
    if sonBatchGoster == 0
        row += 1
        table.cell(dash, 0, row, "—", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
        table.cell(dash, 1, row, "Henuz batch yok", text_color=color.gray, text_size=size.small, text_halign=text.align_right)
    else
        for k = 0 to sonBatchGoster - 1
            ringI = (sonBatchIdx - 1 - k) % RING_SIZE
            if ringI < 0
                ringI += RING_SIZE
            bKar   = array.get(sonBatchKar,   ringI)
            bHisse = array.get(sonBatchHisse, ringI)
            bYuzde = array.get(sonBatchYuzde, ringI)
            bNo    = sonBatchIdx - k
            bRenk  = bKar >= 0 ? color.green : color.red

            row += 1
            table.cell(dash, 0, row, "#" + str.tostring(bNo), text_color=color.white, text_size=size.small, text_halign=text.align_left)
            table.cell(dash, 1, row, str.tostring(bHisse) + "h, " + str.tostring(bKar, "#,###") + " TL (" + str.tostring(bYuzde, "#.##") + "%)", text_color=bRenk, text_size=size.small, text_halign=text.align_right)
