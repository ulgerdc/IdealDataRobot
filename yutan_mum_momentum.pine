// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Kapanis Momentum Overnight Backtest
// Kapanista zirveye yakin kapanan + guclu momentum gosteren hisseleri toplu al, ertesi gun acilista toplu sat
// Sinyal: Close ≈ High + gun ici momentum + hacim artisi + dunden yukari
// Opsiyonel: Engulfing filtresi eklenebilir

//@version=5
indicator("Momentum Overnight Backtest (BIST30)", overlay=false, max_labels_count=500, max_lines_count=500)

// ==================== PARAMETRELER ====================
grp_date    = "Tarih Araligi"
grp_strat   = "Strateji Ayarlari"
grp_mom     = "Momentum Filtre Ayarlari"
grp_endeks  = "Endeks Filtresi"
grp_hisse   = "Hisse Secimi (BIST30)"

startDate   = input.time(timestamp("2024-01-01 00:00 +0300"), "Baslangic Tarihi", group=grp_date)
endDate     = input.time(timestamp("2026-02-25 23:59 +0300"), "Bitis Tarihi",     group=grp_date)

toplamButce     = input.float(100000, "Toplam Butce (TL)",        minval=10000, step=10000, group=grp_strat)
minButcePerHisse= input.float(1000,   "Min Butce/Hisse (TL)",     minval=100, step=100, group=grp_strat)

closeThreshold  = input.float(0.80,   "Kapanis/Zirve Esigi",     minval=0.5, maxval=0.98, step=0.05, group=grp_mom, tooltip="Close'un gun ici range icindeki pozisyonu. 0.80 = ust %20 bolge (zirveye yakin)")
minMomentum     = input.float(1.0,    "Min Gun Ici Momentum (%)", minval=0.1, maxval=5.0, step=0.1, group=grp_mom, tooltip="(Close-Open)/Open yuzde. 1.0 = en az %1 gun ici yukselis")
volCarpani      = input.float(1.0,    "Hacim Carpani (vs dunku)", minval=0.5, maxval=5.0, step=0.1, group=grp_mom, tooltip="Bugun hacim > dunku hacim x carpan")
dununUstuZorunlu = input.bool(true,   "Dunku Kapanis Ustu",      group=grp_mom, tooltip="Close > Close[1] zorunlulugu")
engulfingEk     = input.bool(false,   "Engulfing Filtresi Ekle", group=grp_mom, tooltip="Acik: Momentum + Engulfing birlikte. Kapali: sadece Momentum")
minHacimCarpani = input.float(1.0,    "Engulfing Hacim Carpani", minval=0.5, maxval=5.0, step=0.1, group=grp_mom, tooltip="Engulfing icin: bugun hacim > dunku hacim x carpan")

endeksFiltresi  = input.bool(true,    "XU100 Pozitif Filtresi",  group=grp_endeks)

// BIST30 hisse secimi
e01 = input.bool(true, "AKBNK", group=grp_hisse, inline="r1")
e02 = input.bool(true, "ARCLK", group=grp_hisse, inline="r1")
e03 = input.bool(true, "ASELS", group=grp_hisse, inline="r1")
e04 = input.bool(true, "BIMAS", group=grp_hisse, inline="r1")
e05 = input.bool(true, "EKGYO", group=grp_hisse, inline="r1")
e06 = input.bool(true, "ENJSA", group=grp_hisse, inline="r2")
e07 = input.bool(true, "ENKAI", group=grp_hisse, inline="r2")
e08 = input.bool(true, "EREGL", group=grp_hisse, inline="r2")
e09 = input.bool(true, "FROTO", group=grp_hisse, inline="r2")
e10 = input.bool(true, "GARAN", group=grp_hisse, inline="r2")
e11 = input.bool(true, "GUBRF", group=grp_hisse, inline="r3")
e12 = input.bool(true, "HALKB", group=grp_hisse, inline="r3")
e13 = input.bool(true, "ISCTR", group=grp_hisse, inline="r3")
e14 = input.bool(true, "KCHOL", group=grp_hisse, inline="r3")
e15 = input.bool(true, "KOZAL", group=grp_hisse, inline="r3")
e16 = input.bool(true, "KRDMD", group=grp_hisse, inline="r4")
e17 = input.bool(true, "MGROS", group=grp_hisse, inline="r4")
e18 = input.bool(true, "ODAS",  group=grp_hisse, inline="r4")
e19 = input.bool(true, "PETKM", group=grp_hisse, inline="r4")
e20 = input.bool(true, "PGSUS", group=grp_hisse, inline="r4")
e21 = input.bool(true, "SAHOL", group=grp_hisse, inline="r5")
e22 = input.bool(true, "SASA",  group=grp_hisse, inline="r5")
e23 = input.bool(true, "SISE",  group=grp_hisse, inline="r5")
e24 = input.bool(true, "TCELL", group=grp_hisse, inline="r5")
e25 = input.bool(true, "THYAO", group=grp_hisse, inline="r5")
e26 = input.bool(true, "TOASO", group=grp_hisse, inline="r6")
e27 = input.bool(true, "TTKOM", group=grp_hisse, inline="r6")
e28 = input.bool(true, "TUPRS", group=grp_hisse, inline="r6")
e29 = input.bool(true, "VAKBN", group=grp_hisse, inline="r6")
e30 = input.bool(true, "YKBNK", group=grp_hisse, inline="r6")

// ==================== SABITLER ====================
int MAX_HISSE = 30

// ==================== VERI ALMA ====================
tf = "D"

// XU100 endeks verisi
[xu100O, xu100C] = request.security("BIST:XU100", tf, [open, close], lookahead=barmerge.lookahead_off)
endeksPozitif = xu100C > xu100O

// 30 hisse — her biri: [open, high, low, close, volume, open[1], high[1], close[1], volume[1]]
[o01,h01,l01,c01,v01,po01,ph01,pc01,pv01] = request.security("BIST:AKBNK", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o02,h02,l02,c02,v02,po02,ph02,pc02,pv02] = request.security("BIST:ARCLK", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o03,h03,l03,c03,v03,po03,ph03,pc03,pv03] = request.security("BIST:ASELS", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o04,h04,l04,c04,v04,po04,ph04,pc04,pv04] = request.security("BIST:BIMAS", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o05,h05,l05,c05,v05,po05,ph05,pc05,pv05] = request.security("BIST:EKGYO", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o06,h06,l06,c06,v06,po06,ph06,pc06,pv06] = request.security("BIST:ENJSA", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o07,h07,l07,c07,v07,po07,ph07,pc07,pv07] = request.security("BIST:ENKAI", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o08,h08,l08,c08,v08,po08,ph08,pc08,pv08] = request.security("BIST:EREGL", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o09,h09,l09,c09,v09,po09,ph09,pc09,pv09] = request.security("BIST:FROTO", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o10,h10,l10,c10,v10,po10,ph10,pc10,pv10] = request.security("BIST:GARAN", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o11,h11,l11,c11,v11,po11,ph11,pc11,pv11] = request.security("BIST:GUBRF", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o12,h12,l12,c12,v12,po12,ph12,pc12,pv12] = request.security("BIST:HALKB", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o13,h13,l13,c13,v13,po13,ph13,pc13,pv13] = request.security("BIST:ISCTR", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o14,h14,l14,c14,v14,po14,ph14,pc14,pv14] = request.security("BIST:KCHOL", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o15,h15,l15,c15,v15,po15,ph15,pc15,pv15] = request.security("BIST:KOZAL", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o16,h16,l16,c16,v16,po16,ph16,pc16,pv16] = request.security("BIST:KRDMD", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o17,h17,l17,c17,v17,po17,ph17,pc17,pv17] = request.security("BIST:MGROS", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o18,h18,l18,c18,v18,po18,ph18,pc18,pv18] = request.security("BIST:ODAS",  tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o19,h19,l19,c19,v19,po19,ph19,pc19,pv19] = request.security("BIST:PETKM", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o20,h20,l20,c20,v20,po20,ph20,pc20,pv20] = request.security("BIST:PGSUS", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o21,h21,l21,c21,v21,po21,ph21,pc21,pv21] = request.security("BIST:SAHOL", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o22,h22,l22,c22,v22,po22,ph22,pc22,pv22] = request.security("BIST:SASA",  tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o23,h23,l23,c23,v23,po23,ph23,pc23,pv23] = request.security("BIST:SISE",  tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o24,h24,l24,c24,v24,po24,ph24,pc24,pv24] = request.security("BIST:TCELL", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o25,h25,l25,c25,v25,po25,ph25,pc25,pv25] = request.security("BIST:THYAO", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o26,h26,l26,c26,v26,po26,ph26,pc26,pv26] = request.security("BIST:TOASO", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o27,h27,l27,c27,v27,po27,ph27,pc27,pv27] = request.security("BIST:TTKOM", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o28,h28,l28,c28,v28,po28,ph28,pc28,pv28] = request.security("BIST:TUPRS", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o29,h29,l29,c29,v29,po29,ph29,pc29,pv29] = request.security("BIST:VAKBN", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)
[o30,h30,l30,c30,v30,po30,ph30,pc30,pv30] = request.security("BIST:YKBNK", tf, [open,high,low,close,volume,open[1],high[1],close[1],volume[1]], lookahead=barmerge.lookahead_off)

// ==================== VERI ARRAYLERE YUKLE ====================
var float[] arrO  = array.new_float(MAX_HISSE, 0.0)
var float[] arrH  = array.new_float(MAX_HISSE, 0.0)
var float[] arrL  = array.new_float(MAX_HISSE, 0.0)
var float[] arrC  = array.new_float(MAX_HISSE, 0.0)
var float[] arrV  = array.new_float(MAX_HISSE, 0.0)
var float[] arrO1 = array.new_float(MAX_HISSE, 0.0)
var float[] arrH1 = array.new_float(MAX_HISSE, 0.0)
var float[] arrC1 = array.new_float(MAX_HISSE, 0.0)
var float[] arrV1 = array.new_float(MAX_HISSE, 0.0)
var bool[]  arrAktif = array.new_bool(MAX_HISSE, false)

array.set(arrAktif, 0, e01)
array.set(arrAktif, 1, e02)
array.set(arrAktif, 2, e03)
array.set(arrAktif, 3, e04)
array.set(arrAktif, 4, e05)
array.set(arrAktif, 5, e06)
